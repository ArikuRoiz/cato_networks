# .env.example — copy to .env and fill in your values.
# Never commit .env — it is excluded by .gitignore.

# ---------------------------------------------------------------------------
# Required for live LLM calls (not needed for eval/CI which uses cassettes)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# Database — default matches docker-compose.yml; override for external DB
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://firm:firm@localhost:5432/firm

# ---------------------------------------------------------------------------
# Slack — optional; fake adapter is used when absent
# ---------------------------------------------------------------------------
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL=#trading-desk

# ---------------------------------------------------------------------------
# Langfuse observability — optional; traces are suppressed when absent
# ---------------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://localhost:3000

# ---------------------------------------------------------------------------
# OpenTelemetry — optional; defaults to localhost:4317 (no-op if unavailable)
# ---------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ---------------------------------------------------------------------------
# Langfuse docker-compose secrets — change in production
# ---------------------------------------------------------------------------
NEXTAUTH_SECRET=dev-secret-not-for-production
SALT=dev-salt-not-for-production
